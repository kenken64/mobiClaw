# Port for the web server
PORT=3000

# Path to adb executable (optional - auto-detected if not set)
# ADB_PATH=C:\platform-tools\adb.exe

# AI Agent - set ONE of these API keys (priority: Gemini > OpenAI > Anthropic):
#
# GEMINI_API_KEY=...               # Best for Android UI (Google makes Android)
# GEMINI_MODEL=gemini-2.5-flash    # default: fast, vision, cheap
#
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o              # default: gpt-4o (best vision)
#
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Optional OCR fusion (requires GEMINI_API_KEY)
# AGENT_OCR_ENABLE=1
# AGENT_OCR_EVERY_N_STEPS=2
# AGENT_OCR_MAX_RESULTS=12
# GEMINI_OCR_MODEL=gemini-2.5-flash-lite

# Modal heuristics tuning
# AGENT_MODAL_PANEL_MIN_RATIO=0.45
# AGENT_MODAL_TOP_REGION_MAX=0.20
# AGENT_MODAL_CENTER_MIN_RATIO=0.08
# AGENT_MODAL_DEBUG=1

# Agent loop tuning
# AGENT_MAX_STEPS=20
# AGENT_STEP_DELAY_MS=800

# Benchmark command tuning
# BENCHMARK_MAX_STEPS=12
# BENCHMARK_STEP_DELAY_MS=300

# Scrcpy H.264 settings
# SCRCPY_MAX_SIZE=1280       # Max dimension (0 = no limit)
# SCRCPY_BITRATE=8000000     # Video bitrate in bps (8Mbps default)
# SCRCPY_MAX_FPS=60          # Max frames per second
